# Resonant Environment Variables
# Copy to .env and fill in your values.
#
# NOTE: No API key needed — Resonant uses Claude Code Agent SDK,
# which authenticates through your Claude Code subscription.
# Just make sure you're logged into Claude Code (`claude login`).

# Optional — Override config values via environment
# PORT=3002
# HOST=127.0.0.1
# APP_PASSWORD=
# AGENT_CWD=.
# AGENT_MODEL=claude-sonnet-4-6
# COMPANION_NAME=Echo
# USER_NAME=Alex

# Voice (optional)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Transcription (optional)
# GROQ_API_KEY=

# Prosody analysis (optional)
# HUME_API_KEY=

# Discord bot (optional)
# DISCORD_BOT_TOKEN=
# DISCORD_ENABLED=false

# Telegram bot (optional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ENABLED=false

# Push notifications (optional)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:you@example.com
